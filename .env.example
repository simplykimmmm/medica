# OpenAI API access
OPENAI_API_KEY=

# Default model used when OPENAI_API_KEY is present.
AI_MODEL=gpt-5-mini

# Optional: use any OpenAI-compatible API instead of OpenAI directly.
# If you set only AI_API_KEY, the app defaults to Google AI Studio
# using the Gemini OpenAI-compatible endpoint and gemini-2.5-flash.
AI_API_KEY=
AI_BASE_URL=
AI_PROVIDER_NAME=

# Optional: used for provider headers and deployment docs.
APP_BASE_URL=http://localhost:3000
